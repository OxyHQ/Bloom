{
  "name": "@oxyhq/bloom",
  "version": "0.1.0",
  "description": "Bloom UI — Oxy ecosystem component library for React Native + Expo + Web",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/commonjs/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "sideEffects": false,
